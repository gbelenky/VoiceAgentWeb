<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>VoiceAgentWeb.Server</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.AI.VoiceLive" Version="1.0.0" />
    <PackageReference Include="Azure.Identity" Version="1.13.*" />
    <PackageReference Include="Microsoft.Identity.Web" Version="3.*" />
  </ItemGroup>

  <Target Name="PublishClient" BeforeTargets="Build">
    <Exec Command="dotnet publish ../Client -c $(Configuration) -o $(MSBuildThisFileDirectory)_client_publish" />
    <ItemGroup>
      <ClientFiles Include="$(MSBuildThisFileDirectory)_client_publish\wwwroot\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(ClientFiles)" DestinationFolder="$(MSBuildThisFileDirectory)wwwroot\%(RecursiveDir)" />
  </Target>

</Project>
